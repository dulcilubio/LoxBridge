    "GPX files are permanently deleted from this device. Routes already on Livelox are not affected." : {
      "comment" : "HistoryView - delete confirmation message",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Soubory GPX jsou trvale smazány z tohoto zařízení. Trasy již na Livelox nejsou ovlivněny." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "GPX-tiedostot poistetaan pysyvästi tästä laitteesta. Liveloxissa jo oleviin reitteihin ei vaikuteta." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Les fichiers GPX sont définitivement supprimés de cet appareil. Les itinéraires déjà sur Livelox ne sont pas affectés." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "GPX-filer tas bort permanent från den här enheten. Rutter som redan finns på Livelox påverkas inte." } }
      }
    },

