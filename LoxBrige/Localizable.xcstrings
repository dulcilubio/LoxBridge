        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Soubory GPX jsou trvale smazány z tohoto zařízení. Trasy již na Livelox nejsou ovlivněny." } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "GPX-filer slettes permanent fra denne enhed. Ruter der allerede er på Livelox, påvirkes ikke." } },
