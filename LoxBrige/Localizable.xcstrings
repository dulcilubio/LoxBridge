        "et" : { "stringUnit" : { "state" : "translated", "value" : "Sinu GPX-rada on Liveloxisse üles laaditud." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "GPX-reittisi on ladattu Liveloxiin." } },
