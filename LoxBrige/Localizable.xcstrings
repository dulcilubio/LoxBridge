      }
    },

    "LoxBridge reads your Apple Watch and iPhone workout routes through the Apple Health app to generate GPX files. Tap below to grant access." : {
      "comment" : "OnboardingView - HealthKit step description",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge čte vaše trasy tréninků z Apple Watch a iPhone prostřednictvím aplikace Apple Health pro generování GPX souborů. Klepnutím níže udělte přístup." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge lukee harjoitusreittisi Apple Watchista ja iPhonesta Apple Terveys -sovelluksen kautta GPX-tiedostojen luomiseksi. Napauta alla myöntääksesi käyttöoikeuden." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge lit vos itinéraires d'entraînement de l'Apple Watch et de l'iPhone via l'application Apple Santé pour générer des fichiers GPX. Appuyez ci-dessous pour accorder l'accès." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge läser dina träningsrutter från Apple Watch och iPhone via appen Apple Hälsa för att generera GPX-filer. Tryck nedan för att bevilja åtkomst." } }
      }
    },

    "LoxBridge is designed to keep you in control of your personal data. Here's exactly what the app does with it." : {
      "comment" : "PrivacyView - intro text",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge je navržen tak, abyste měli kontrolu nad svými osobními údaji. Zde je přesně to, co aplikace s nimi dělá." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge on suunniteltu pitämään sinut henkilötietojesi hallinnassa. Tässä on tarkalleen mitä sovellus tekee niillä." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge est conçu pour vous garder maître de vos données personnelles. Voici exactement ce que l'application en fait." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge är utformat för att du ska ha kontroll över dina personuppgifter. Här är exakt vad appen gör med dem." } }
      }
    },

    "LoxBridge reads your workout GPS routes from Apple Health and sends them to Livelox — only when you choose. Your data never goes anywhere else, is never sold, and is never used for advertising." : {
      "comment" : "OnboardingView - privacy step description",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge čte GPS trasy vašich tréninků z Apple Health a odesílá je do Livelox — pouze když zvolíte. Vaše data nikam jinam nejdou, nejsou prodávána ani používána pro reklamu." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge lukee harjoituksesi GPS-reitit Apple Terveydestä ja lähettää ne Liveloxiin — vain kun valitset niin. Tietosi eivät mene muualle, niitä ei myydä eikä käytetä mainontaan." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge lit vos itinéraires GPS d'entraînement depuis Apple Santé et les envoie à Livelox — uniquement sur votre demande. Vos données ne vont nulle part ailleurs, ne sont jamais vendues et ne sont jamais utilisées à des fins publicitaires." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge läser dina träningspass och GPS-spår från Apple Hälsa och skickar dem till Livelox — bara när du väljer det. Din data går aldrig någon annanstans, säljs aldrig och används aldrig för reklam." } }
      }
    },

    "LoxBridge will run in the background. After each outdoor workout you'll receive a notification to upload the route." : {
      "comment" : "OnboardingView - all set step description",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge poběží na pozadí. Po každém venkovním tréninku obdržíte oznámení o nahrání trasy." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge toimii taustalla. Jokaisen ulkoharjoituksen jälkeen saat ilmoituksen reitin lataamisesta." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge fonctionnera en arrière-plan. Après chaque entraînement en extérieur, vous recevrez une notification pour transférer l'itinéraire." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "LoxBridge körs i bakgrunden. Efter varje utomhusträningspass får du ett meddelande om att ladda upp rutten." } }
      }
    },

