    "Connect Livelox" : {
      "comment" : "OnboardingView - Livelox step title and button / SettingsView - button",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Připojit Livelox" } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Yhdistä Livelox" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Connecter Livelox" } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Anslut Livelox" } }
      }
    },

    "Connect your Livelox account to upload workout routes automatically." : {
      "comment" : "NotificationManager - needs auth notification body",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Připojte svůj účet Livelox pro automatické nahrávání tras tréninků." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Yhdistä Livelox-tilisi ladataksesi harjoitusreittejä automaattisesti." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Connectez votre compte Livelox pour transférer les itinéraires automatiquement." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Anslut ditt Livelox-konto för att ladda upp träningsrutter automatiskt." } }
      }
    },

