    },
    "Your Livelox session has expired — go to Settings → Connections to reconnect." : {
      "comment" : "AppError - tokenRefreshFailed",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Vaše relace Livelox vypršela — přejděte do Nastavení → Připojení a znovu se připojte." } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Din Livelox-session er udløbet — gå til Indstillinger → Forbindelser for at oprette forbindelsen igen." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Deine Livelox-Sitzung ist abgelaufen — gehe zu Einstellungen → Verbindungen, um dich erneut zu verbinden." } },
        "et" : { "stringUnit" : { "state" : "translated", "value" : "Sinu Livelox seanss on aegunud — mine Seaded → Ühendused uuesti ühendamiseks." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Livelox-istuntosi on vanhentunut — siirry Asetukset → Yhteydet yhdistääksesi uudelleen." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Votre session Livelox a expiré — accédez à Réglages → Connexions pour vous reconnecter." } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Livelox-økten din har utløpt — gå til Innstillinger → Tilkoblinger for å koble til igjen." } },
