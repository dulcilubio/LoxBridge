    },
    "Authorization callback did not contain a valid code." : {
      "comment" : "AppError - oauthCallbackInvalid",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Zpětné volání autorizace neobsahovalo platný kód." } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Autoriserings-callbacken indeholdt ikke en gyldig kode." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Der Autorisierungs-Callback enthielt keinen gültigen Code." } },
        "et" : { "stringUnit" : { "state" : "translated", "value" : "Autoriseerimise tagasihelistamine ei sisaldanud kehtivat koodi." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Valtuutuksen takaisinkutsu ei sisältänyt kelvollista koodia." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le rappel d'autorisation ne contenait pas de code valide." } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Autoriseringscallbacken inneholdt ikke en gyldig kode." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Auktoriseringscallbacken innehöll ingen giltig kod." } }
      }
    },
    "Authorization was cancelled." : {
      "comment" : "AppError - oauthCancelled",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Autorizace byla zrušena." } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Autorisering blev annulleret." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Autorisierung wurde abgebrochen." } },
        "et" : { "stringUnit" : { "state" : "translated", "value" : "Autoriseerimine tühistati." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Valtuutus peruutettiin." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "L'autorisation a été annulée." } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Autorisering ble avbrutt." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Auktoriseringen avbröts." } }
      }
    },
    "Authorize Health Access" : {
      "comment" : "OnboardingView - HealthKit step button",
      "extractionState" : "stale",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Autorizovat přístup ke zdraví" } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Autoriser sundhedsadgang" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Gesundheitszugriff autorisieren" } },
        "et" : { "stringUnit" : { "state" : "translated", "value" : "Volita terviseandmete juurdepääs" } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Valtuuta terveyskäyttöoikeus" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Autoriser l'accès à la santé" } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Autoriser helsetilgang" } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Auktorisera hälsoåtkomst" } }
      }
    },
    "Automatically bridge your orienteering runs to Livelox — whether you run with Apple Watch or iPhone. After each workout, LoxBridge extracts your GPS route and uploads it to Livelox with no cables and no manual exports. Just run, and your route appears in Livelox ready to replay and share." : {
      "comment" : "HomeView - app description",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Automaticky propojte své orientační běhy s Livelox — ať už běžíte s Apple Watch nebo iPhonem. Po každém tréninku LoxBridge extrahuje vaši GPS trasu a nahraje ji do Livelox bez kabelů a ručního exportu. Stačí běžet a vaše trasa se zobrazí v Livelox připravená k přehrání a sdílení." } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Forbind automatisk dine orienteringsløb med Livelox — uanset om du løber med Apple Watch eller iPhone. Efter hvert træningspas udtrækker LoxBridge din GPS-rute og uploader den til Livelox uden kabler og manuel eksport. Løb bare, og din rute vises i Livelox klar til afspilning og deling." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Verbinde deine Orientierungsläufe automatisch mit Livelox – ob mit Apple Watch oder iPhone. Nach jedem Training extrahiert LoxBridge deine GPS-Route und lädt sie ohne Kabel und manuelle Exporte in Livelox hoch. Lauf einfach los, und deine Route erscheint in Livelox zur Wiedergabe und zum Teilen." } },
        "et" : { "stringUnit" : { "state" : "translated", "value" : "Ühenda oma orienteerumisrajad automaatselt Liveloxiga — olenemata sellest, kas jooksed Apple Watchiga või iPhonega. Pärast iga treeningut eraldab LoxBridge sinu GPS-raja ja laadib selle Liveloxisse üles ilma kaablite ja käsitsi ekspordita. Jookse lihtsalt ja sinu rada ilmub Liveloxis taasesitamiseks ja jagamiseks." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Yhdistä orientointijuoksusi automaattisesti Liveloxiin — riippumatta siitä, juoksetko Apple Watchin vai iPhonen kanssa. Jokaisen harjoituksen jälkeen LoxBridge poimii GPS-reittisi ja lataa sen Liveloxiin ilman kaapeleita ja manuaalisia vientejä. Juokse vain, ja reittisi näkyy Liveloxissa valmiina toistettavaksi ja jaettavaksi." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Synchronisez automatiquement vos courses d'orientation avec Livelox — que vous couriez avec l'Apple Watch ou l'iPhone. Après chaque entraînement, LoxBridge extrait votre itinéraire GPS et le transfère vers Livelox sans câbles ni exportation manuelle. Courez simplement, et votre itinéraire apparaît dans Livelox prêt à être relu et partagé." } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Koble orienteringsløpene dine automatisk til Livelox — enten du løper med Apple Watch eller iPhone. Etter hver økt henter LoxBridge GPS-ruten din og laster den opp til Livelox uten kabler og manuell eksport. Bare løp, og ruten din vises i Livelox klar til å spilles av og deles." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Koppla automatiskt dina orienteringslöpningar till Livelox — oavsett om du springer med Apple Watch eller iPhone. Efter varje träningspass extraherar LoxBridge ditt GPS-spår och laddar upp det till Livelox utan kablar och utan manuell export. Spring, och din rutt visas i Livelox redo att spela upp och dela." } }
      }
    },
    "Complete an outdoor workout with your Apple Watch and it will appear here." : {
      "comment" : "HistoryView - empty state subtitle",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Dokončete venkovní trénink s Apple Watch a zobrazí se zde." } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Gennemfør en udendørs træning med dit Apple Watch, og den vises her." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Schließe ein Outdoor-Training mit deiner Apple Watch ab und es erscheint hier." } },
        "et" : { "stringUnit" : { "state" : "translated", "value" : "Lõpeta õuetreening Apple Watchiga ja see ilmub siia." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Suorita ulkoharjoitus Apple Watchillasi, ja se näkyy täällä." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Terminez un entraînement en extérieur avec votre Apple Watch et il apparaîtra ici." } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Fullfør en utendørs treningsøkt med Apple Watch, så vises den her." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Slutför ett utomhusträningspass med din Apple Watch så visas det här." } }
      }
    },
