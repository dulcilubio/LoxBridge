    "Sign in to your Livelox account so routes can be uploaded automatically after each workout." : {
      "comment" : "OnboardingView - Livelox step description",
      "extractionState" : "stale",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Přihlaste se ke svému účtu Livelox, aby trasy mohly být nahrávány automaticky po každém tréninku." } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Log ind på din Livelox-konto, så ruter uploades automatisk efter hvert træningspas." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Melde dich in deinem Livelox-Konto an, damit Routen nach jedem Training automatisch hochgeladen werden." } },
        "et" : { "stringUnit" : { "state" : "translated", "value" : "Logi sisse oma Livelox kontole, et rajad laaditaks pärast iga treeningut automaatselt üles." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Kirjaudu Livelox-tilillesi, jotta reitit voidaan ladata automaattisesti jokaisen harjoituksen jälkeen." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Connectez-vous à votre compte Livelox pour que les itinéraires soient transférés automatiquement après chaque entraînement." } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Logg inn på Livelox-kontoen din slik at ruter lastes opp automatisk etter hver treningsøkt." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Logga in på ditt Livelox-konto så att rutter kan laddas upp automatiskt efter varje träningspass." } }
      }
    },
    "Skip for now" : {
