      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Pro nahrávání otevřete aplikaci **Cvičení** na Apple Watch a zvolte Běh venku" } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "For at optage skal du åbne **Træning**-appen på dit Apple Watch og vælge Udendørsløb" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zum Aufzeichnen öffne die **Training**-App auf deiner Apple Watch und wähle Outdoor-Lauf" } },
        "et" : { "stringUnit" : { "state" : "translated", "value" : "Salvestamiseks avage Apple Watchis **Treening** rakendus ja valige Õuejooks" } },
