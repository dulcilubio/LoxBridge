        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kirjaudu Livelox-tilillesi, jotta reitit ladataan automaattisesti jokaisen aktiviteetin jälkeen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
