        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Uživatelská smlouva Livelox" } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Liveloxin käyttösopimus" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Conditions d'utilisation Livelox" } },
