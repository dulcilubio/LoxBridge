    },
    "We are uploading your workout route in the background." : {
      "comment" : "NotificationManager - auto upload started body",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Vaše trasa tréninku se nahrává na pozadí." } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Vi uploader din træningsrute i baggrunden." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Deine Trainingsroute wird im Hintergrund hochgeladen." } },
        "et" : { "stringUnit" : { "state" : "translated", "value" : "Laadime sinu treeningrada taustal üles." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Harjoitusreittiäsi ladataan taustalla." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Votre itinéraire d'entraînement est en cours de transfert en arrière-plan." } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Vi laster opp treningsruten din i bakgrunnen." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Vi laddar upp din träningsrutt i bakgrunden." } }
      }
    },
    "Workouts shorter than %.1f km will not be sent to Livelox" : {
      "comment" : "SettingsView - distance filter caption, %.1f = distance in km",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Tréninky kratší než %.1f km nebudou odeslány do Livelox" } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Træninger kortere end %.1f km sendes ikke til Livelox" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Trainings kürzer als %.1f km werden nicht an Livelox gesendet" } },
        "et" : { "stringUnit" : { "state" : "translated", "value" : "Treeninguid, mis on lühemad kui %.1f km, ei saadeta Liveloxile" } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "Alle %.1f km harjoituksia ei lähetetä Liveloxiin" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Les entraînements de moins de %.1f km ne seront pas envoyés à Livelox" } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Treningsøkter kortere enn %.1f km sendes ikke til Livelox" } },
