    "Go to Settings → Health → Apps → LoxBridge at any time to remove access. LoxBridge will stop detecting new workouts immediately." : {
      "comment" : "Privacy row for revoking HealthKit access.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přejděte do Nastavení → Zdraví → Aplikace → LoxBridge a odeberte přístup. LoxBridge okamžitě přestane zjišťovat nová cvičení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gå til Indstillinger → Helbred → Apps → LoxBridge for at fjerne adgang. LoxBridge stopper øjeblikkeligt med at registrere nye træninger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gehe zu Einstellungen → Gesundheit → Apps → LoxBridge, um den Zugriff zu entfernen. LoxBridge erkennt sofort keine neuen Trainings mehr."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mine Seaded → Tervis → Rakendused → LoxBridge, et eemaldada juurdepääs. LoxBridge lõpetab kohe uute treeningute tuvastamise."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siirry Asetukset → Terveys → Sovellukset → LoxBridge poistaaksesi käyttöoikeuden. LoxBridge lopettaa uusien harjoitusten havaitsemisen välittömästi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accédez à Réglages → Santé → Apps → LoxBridge pour supprimer l'accès. LoxBridge cessera immédiatement de détecter de nouveaux entraînements."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gå til Innstillinger → Helse → Apper → LoxBridge for å fjerne tilgang. LoxBridge slutter umiddelbart å oppdage nye treningsøkter."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gå till Inställningar → Hälsa → Appar → LoxBridge för att ta bort åtkomst. LoxBridge slutar omedelbart att identifiera nya träningspass."
          }
        }
      }
    },
