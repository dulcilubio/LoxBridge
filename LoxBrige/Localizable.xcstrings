      }
    },

    "HealthKit access was removed. Re-authorize in Settings to resume automatic uploads." : {
      "comment" : "AppViewModel - error shown when HealthKit permission is revoked",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Přístup k HealthKit byl odebrán. Znovu autorizujte v Nastavení pro obnovení automatického nahrávání." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "HealthKit-käyttöoikeus on poistettu. Valtuuta uudelleen Asetukset-kohdassa jatkaaksesi automaattisia latauksia." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "L'accès à HealthKit a été révoqué. Réautorisez dans Réglages pour reprendre les transferts automatiques." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Åtkomst till HealthKit har tagits bort. Auktorisera igen under Inställningar för att återuppta automatiska uppladdningar." } }
      }
    },

    "HealthKit is not available on this device." : {
      "comment" : "AppError - healthKitUnavailable",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "HealthKit není na tomto zařízení k dispozici." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "HealthKit ei ole saatavilla tässä laitteessa." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "HealthKit n'est pas disponible sur cet appareil." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "HealthKit är inte tillgängligt på den här enheten." } }
      }
    },

    "Home" : {
