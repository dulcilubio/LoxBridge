    "GPX files are permanently deleted from this device. Routes already on Livelox are not affected." : {
      "comment" : "HistoryView - delete confirmation message",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soubory GPX jsou trvale smazány z tohoto zařízení. Trasy již na Livelox nejsou ovlivněny."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPX-filer slettes permanent fra denne enhed. Ruter der allerede er på Livelox, påvirkes ikke."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPX-Dateien werden dauerhaft von diesem Gerät gelöscht. Bereits in Livelox hochgeladene Routen sind nicht betroffen."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPX-failid kustutatakse sellest seadmest jäädavalt. Liveloxis juba olevaid radasid see ei mõjuta."
