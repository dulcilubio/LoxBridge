      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Autorizace HealthKit selhala." } },
        "fi" : { "stringUnit" : { "state" : "translated", "value" : "HealthKit-valtuutus epäonnistui." } },
