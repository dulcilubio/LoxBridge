    "Do you want to upload the GPS route to Livelox?" : {
      "comment" : "NotificationManager - upload prompt body",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Chcete nahrát GPS trasu do Livelox?" } },
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Vil du uploade GPS-ruten til Livelox?" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Möchtest du die GPS-Route zu Livelox hochladen?" } },
